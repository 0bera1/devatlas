generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String
  birthDate     DateTime
  createdAt     DateTime       @default(now())
  documents     Document[]
  refreshTokens RefreshToken[]
}

model Document {
  id         String     @id @default(cuid())
  title      String
  content    String     @default("")
  ownerId    String
  visibility Visibility @default(PRIVATE)
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([visibility])
}

/// Platform içeriği: kullanıcıya bağlı değil; arama ve gelecekteki graph katmanı için ayrı koleksiyon.
model SystemContent {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  createdAt DateTime @default(now())

  @@index([type])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

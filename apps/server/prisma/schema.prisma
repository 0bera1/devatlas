generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  password      String
  birthDate     DateTime
  createdAt     DateTime       @default(now())
  documents     Document[]
  diagrams      Diagram[]
  favorites     Favorite[]
  diagramFavorites DiagramFavorite[]
  refreshTokens RefreshToken[]
  diagramCollaborations DiagramCollaborator[]
  activityBuckets UserActivityBucket[]
}

/// Node tabanlı bilgi haritası (graph); dokümanla birlikte arama / keşif için.
model Diagram {
  id         String     @id @default(cuid())
  title      String
  visibility Visibility @default(PRIVATE)

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  nodes Node[]
  edges Edge[]

  collaborators DiagramCollaborator[]
  diagramFavorites DiagramFavorite[]

  /// Favorileyen kullanıcı sayısı (DiagramFavorite satırlarıyla tutarlı tutulmalı).
  favoriteCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([visibility])
}

model Node {
  id        String @id
  diagramId String
  label     String
  type      String
  x         Float
  y         Float
  width     Float?
  height    Float?
  /// İç içe / bağlantılı diyagram önizlemesi için hedef diyagram id (opsiyonel).
  relatedDiagramId String?
  /// Düğüm detayı: açıklama, markdown, etiketler, durum vb. (API’de ayrı kolonlar yerine JSON).
  extras Json?

  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  outgoingEdges Edge[] @relation("DiagramEdgeFrom")
  incomingEdges Edge[] @relation("DiagramEdgeTo")

  @@index([diagramId])
}

model Edge {
  id         String @id @default(cuid())
  diagramId  String
  fromNodeId String
  toNodeId   String
  label      String?
  type       String?
  animated   Boolean @default(false)

  diagram  Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  fromNode Node    @relation("DiagramEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   Node    @relation("DiagramEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model DiagramCollaborator {
  diagramId String
  userId    String
  createdAt DateTime @default(now())

  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([diagramId, userId])
  @@index([userId])
}

model Document {
  id         String     @id @default(cuid())
  title      String
  content    String     @default("")
  visibility Visibility @default(PRIVATE)

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  /// Toplam görüntülenme (AŞAMA 1 — algoritma verisi; artırma mantığı sonraki aşamada).
  viewCount Int @default(0)
  /// Favorileyen kullanıcı sayısı (Favorite satırlarıyla tutarlı tutulmalı).
  favoriteCount Int @default(0)

  favorites Favorite[]
  viewBuckets DocumentViewBucket[]
  documentTags DocumentTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([visibility])
  @@index([categoryId])
}

model Category {
  id   String @id @default(cuid())
  name String @unique

  documents Document[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  documentTags DocumentTag[]
}

/// Doküman–etiket çoktan çoğa ilişki tablosu.
model DocumentTag {
  documentId String
  tagId      String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
}

/// Kullanıcı–doküman favori ilişkisi (öneri / engagement için ayrı tablo).
model Favorite {
  id         String @id @default(cuid())
  userId     String
  documentId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, documentId])
}

/// Kullanıcı–diyagram favori ilişkisi; doküman favorisi ile paralel yapıda.
model DiagramFavorite {
  id        String @id @default(cuid())
  userId    String
  diagramId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, diagramId])
  @@index([diagramId])
}

/// Kullanıcının günlük üretim aktivitesi (oluşturma + kaydetme). GitHub-style heatmap kaynağı.
/// Aynı kullanıcı + aynı UTC günü için tek bir satır olur; her save action `count` alanını +1 yapar.
model UserActivityBucket {
  id         String   @id @default(cuid())
  userId     String
  bucketDate DateTime @db.Date
  count      Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bucketDate])
  @@index([userId])
}

/// Aynı izleyici + doküman + UTC günü için en fazla bir görüntülenme sayımı (spam / F5 önleme).
model DocumentViewBucket {
  id         String   @id @default(cuid())
  documentId String
  /// "user:<userId>" veya "anon:<uuid>"
  viewerKey  String
  bucketDate DateTime @db.Date

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, viewerKey, bucketDate])
  @@index([documentId])
}

/// Platform içeriği: kullanıcıya bağlı değil; arama ve gelecekteki graph katmanı için ayrı koleksiyon.
model SystemContent {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  createdAt DateTime @default(now())

  @@index([type])
}

/// Bilgi tabanı — salt okunur sistem dokümanları.
model SystemDocument {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  summary   String?
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

/// Bilgi tabanı — salt okunur sistem diyagramları.
model SystemDiagram {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  narrativeTr   String? @map("narrative_tr")
  narrativeEn   String? @map("narrative_en")
  sortOrder   Int      @default(0)
  nodes       SystemDiagramNode[]
  edges       SystemDiagramEdge[]
  flowSteps   SystemFlowStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model SystemDiagramNode {
  id               String  @id
  diagramId        String
  label            String
  type             String
  x                Float
  y                Float
  width            Float?
  height           Float?
  relatedDiagramId String?
  extras           Json?

  diagram        SystemDiagram       @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  outgoingEdges  SystemDiagramEdge[] @relation("SystemDiagramEdgeFrom")
  incomingEdges  SystemDiagramEdge[] @relation("SystemDiagramEdgeTo")

  @@index([diagramId])
}

model SystemDiagramEdge {
  id         String  @id @default(cuid())
  diagramId  String
  fromNodeId String
  toNodeId   String
  label      String?
  type       String?
  animated   Boolean @default(false)

  diagram  SystemDiagram     @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  fromNode SystemDiagramNode @relation("SystemDiagramEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   SystemDiagramNode @relation("SystemDiagramEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

/// Bilgi tabanı — birbirine bağlı sistem diyagramlarından oluşan akışlar.
model SystemFlow {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  /// Akışın genel amacı ve sıralı okuma rehberi (markdown, TR).
  narrativeTr String? @map("narrative_tr")
  /// Same narrative in English.
  narrativeEn String? @map("narrative_en")
  sortOrder   Int      @default(0)
  steps       SystemFlowStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model SystemFlowStep {
  id        String @id @default(cuid())
  flowId    String
  diagramId String
  stepOrder Int
  label     String
  /// Bu adımda diyagramı nasıl okuyacağınız (markdown, TR).
  narrativeTr String? @map("narrative_tr")
  narrativeEn String? @map("narrative_en")

  flow    SystemFlow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
  diagram SystemDiagram @relation(fields: [diagramId], references: [id], onDelete: Restrict)

  @@unique([flowId, stepOrder])
  @@index([flowId])
  @@index([diagramId])
}

/// AŞAMA 3 — Bilgi platformu: tag tabanlı önerilen mülakat soruları.
/// `tags` Postgres String[] alanı; GIN indeks ile çakışma sorgusu hızlandırılır.
model InterviewQuestion {
  id         String   @id @default(cuid())
  question   String
  answer     String
  tags       String[]
  difficulty String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tags], type: Gin)
  @@index([difficulty])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
